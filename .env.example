# ──────────────────────────────────────────────────────────────────────────────
# PIX-Bridge — Environment Variables
# Copy to .env and fill in the values before running.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Infrastructure Passwords (shared) ─────────────────────────────────────────
POSTGRES_USER=pix_user
POSTGRES_PASSWORD=pix_secret
POSTGRES_DB=bank_b

MONGO_INITDB_DATABASE=bank_a

RABBITMQ_DEFAULT_USER=pix_user
RABBITMQ_DEFAULT_PASS=pix_secret

REDIS_PASSWORD=pix_secret

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID_BANK_A=bank-a-consumer-group
KAFKA_GROUP_ID_BANK_B=bank-b-consumer-group

# ── Orange Bank (Bank A) — NestJS ──────────────────────────────────────────────
NODE_ENV=development
ORANGE_BANK_PORT=3000

MONGODB_URI=mongodb://localhost:27017/bank_a?replicaSet=rs0
MONGODB_DB_NAME=bank_a

REDIS_URL=redis://:pix_secret@localhost:6379

# JWT — generate RS256 key pair: make generate-jwt-keys
# JWT_PRIVATE_KEY and JWT_PUBLIC_KEY hold the raw PEM content (newlines as \n)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=604800

# LLM (OpenAI)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
LLM_CONFIDENCE_THRESHOLD=0.7

# Transactional Outbox Worker
OUTBOX_POLL_INTERVAL_MS=500
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_RETRIES=5

# ── Purple Bank (Bank B) — FastAPI ─────────────────────────────────────────────
PURPLE_BANK_PORT=8000

DATABASE_URL=postgresql+asyncpg://pix_user:pix_secret@localhost:5432/bank_b

RABBITMQ_URL=amqp://pix_user:pix_secret@localhost:5672/
RABBITMQ_QUEUE_NAME=process.pix
RABBITMQ_DLQ_NAME=pix.dlq
RABBITMQ_EXCHANGE=pix.direct
RABBITMQ_MAX_RETRY_ATTEMPTS=3

JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
